# RPC endpoints (WebSocket preferred for real-time)
BASE_RPC_WSS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_HTTPS=https://mainnet.base.org

ARBITRUM_RPC_WSS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_HTTPS=https://arb1.arbitrum.io/rpc

MONAD_RPC_HTTPS=https://testnet-rpc.monad.xyz

# Wallet (NEVER commit real key)
PRIVATE_KEY=0x...

# Strategy params
MIN_PROFIT_USD=5
MAX_GAS_GWEI=50
POLL_INTERVAL_MS=1000

# Execution mode: "direct" | "flashloan"
EXECUTION_MODE=direct

# Direct mode: amount of native token to use per trade
TRADE_AMOUNT_ETH=0.1
